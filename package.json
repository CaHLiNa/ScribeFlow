{
  "name": "scribeflow",
  "private": true,
  "version": "1.0.14",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "guard:ui-bridges": "node ./scripts/check-ui-bridges.mjs",
    "smoke:web-shell": "node ./scripts/smoke-web-shell.mjs",
    "smoke:tauri-window": "node ./scripts/smoke-tauri-window.mjs",
    "smoke:tauri-open-workspace": "node ./scripts/smoke-tauri-open-workspace.mjs",
    "check": "npm run build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:frontend": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify": "npm run guard:ui-bridges && npm run lint && npm run test:frontend && npm run smoke:web-shell && npm run build && npm run check:rust && npm run test:rust",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
