# Public origin of this OAuth bridge.
# Vercel example: https://your-project.vercel.app
# Optional local example: http://localhost:3000
# If you import this monorepo into Vercel, set the Project Root Directory to `web`.
# Copy this file to `web/.env` for local development.
NUXT_BASE_URL=http://localhost:3000

# GitHub OAuth App used by the desktop app.
# End users do NOT create their own OAuth App.
# You create one Altals-owned OAuth App and configure this bridge with it.
# In Vercel, add these values under Project Settings -> Environment Variables.
# Callback URL: {NUXT_BASE_URL}/api/v1/auth/github/callback
NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=
