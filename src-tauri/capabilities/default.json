{
  "identifier": "default",
  "description": "Default capabilities for Altals",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-set-webview-zoom",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "deep-link:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "tinymist-lsp",
          "cmd": "tinymist",
          "args": ["lsp"]
        },
        {
          "name": "tinymist-lsp-managed",
          "cmd": "$HOME/.altals/bin/tinymist",
          "args": ["lsp"]
        },
        {
          "name": "tinymist-lsp-managed-win",
          "cmd": "$HOME/.altals/bin/tinymist.exe",
          "args": ["lsp"]
        },
        {
          "name": "tinymist-lsp-legacy",
          "cmd": "$HOME/.shoulders/bin/tinymist",
          "args": ["lsp"]
        },
        {
          "name": "tinymist-lsp-legacy-win",
          "cmd": "$HOME/.shoulders/bin/tinymist.exe",
          "args": ["lsp"]
        },
        {
          "name": "opencode-cli",
          "cmd": "opencode",
          "args": true
        },
        {
          "name": "bun-opencode-dev",
          "cmd": "bun",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill"
  ]
}
